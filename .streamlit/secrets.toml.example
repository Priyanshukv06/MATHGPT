# ─────────────────────────────────────────────────────────────────
#  Streamlit Secrets Template
#  Location: .streamlit/secrets.toml (local Streamlit Cloud only)
#  
#  For local development: Use .env file instead
#  For Streamlit Cloud: Paste these in Advanced Settings → Secrets
# ─────────────────────────────────────────────────────────────────

# ── LLM Providers (required - choose both for fallback) ──────────────

# NVIDIA NIM API Key (Primary Provider)
# Get from: https://build.nvidia.com/
NVIDIA_API_KEY = "your_nvidia_api_key_here"

# Groq API Key (Fallback Provider)
# Get from: https://console.groq.com/
GROQ_API_KEY = "your_groq_api_key_here"

# ── Optional: Supabase (for persistent session history) ─────────────

# Supabase Project URL
# Get from: https://supabase.com/
SUPABASE_URL = "https://your-project.supabase.co"

# Supabase Anon Key
SUPABASE_KEY = "your_supabase_anon_key_here"

# ─────────────────────────────────────────────────────────────────────
# IMPORTANT NOTES:
# 1. Never commit this file with real keys to git
# 2. For LOCAL testing: Use .env file (already in .gitignore)
# 3. For STREAMLIT CLOUD: Paste contents in Dashboard → Secrets
# 4. Keys are encrypted and safely stored by Streamlit
# 5. If key expires, update secret and restart app
# ─────────────────────────────────────────────────────────────────────
